{
  "name": "pinscribe",
  "version": "1.3.3",
  "description": "macOS annotation tool for design feedback",
  "main": "out/main/index.js",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build && electron-builder --mac dmg",
    "publish": "electron-vite build && electron-builder --mac dmg zip --publish always"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@electron-toolkit/tsconfig": "^1.0.1"
  },
  "build": {
    "appId": "com.finity.pinscribe",
    "productName": "PinScribe",
    "files": [
      "out/**",
      "resources/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "resources/icon.icns",
      "identity": null
    },
    "dmg": {
      "title": "PinScribe"
    },
    "publish": {
      "provider": "github",
      "owner": "trmp10",
      "repo": "pinscribe",
      "releaseType": "release"
    }
  }
}
